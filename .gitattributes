# Handle line endings automatically
* text=auto eol=crlf

# Code files should always be LF
*.cs text eol=lf
*.csproj text eol=lf
*.sln text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf
*.conf text eol=lf
*.sql text eol=lf
*.md text eol=lf

# Binary files
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.dll binary
*.exe binary
